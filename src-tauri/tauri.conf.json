{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M2M Secure Messenger",
  "version": "0.1.0",
  "identifier": "org.m2m.messenger",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "M2M",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; img-src 'self' data:; script-src 'self'; connect-src 'self' ipc:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [],
      "dialog": true
    }
  }
}
